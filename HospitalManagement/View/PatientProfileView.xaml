<Page
    x:Class="HospitalManagement.View.PatientProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:entity="using:HospitalManagement.Entity"
    xmlns:converters="using:HospitalManagement.Converters">

    <Page.Resources>
        <converters:DateToStringConverter x:Key="DateConverter" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Margin="0,0,10,0" Padding="20" CornerRadius="8">
            <StackPanel Spacing="8">
                <TextBlock Text="General Information" FontSize="20" FontWeight="Bold" Foreground="#ffffff"/>

                <TextBlock Text="{x:Bind ViewModel.CurrentPatient.FirstName, Mode=OneWay, FallbackValue='Loading...'}" FontSize="18"/>
                <TextBlock Text="{x:Bind ViewModel.CurrentPatient.LastName, Mode=OneWay, FallbackValue=''}" FontSize="18"/>
                <TextBlock Text="{x:Bind ViewModel.CurrentPatient.Cnp, Mode=OneWay, FallbackValue=''}" Foreground="Gray" Margin="0,0,0,10"/>

                <MenuFlyoutSeparator Margin="0,10"/>

                <TextBlock Text="Medical History" FontWeight="SemiBold" FontSize="16"/>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="Blood Type: " Foreground="Gray"/>
                    <TextBlock Text="{x:Bind ViewModel.CurrentPatient.MedicalHistory.BloodType, Mode=OneWay, TargetNullValue='N/A', FallbackValue='N/A'}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="Chronic Conditions: " Foreground="Gray"/>
                    <TextBlock Text="{x:Bind ViewModel.CurrentPatient.MedicalHistory.ChronicConditions, Mode=OneWay, TargetNullValue='None', FallbackValue='None'}" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Margin="10,0,0,0" Padding="20" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Consultation Details" FontSize="20" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,15"/>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.CurrentPatient.MedicalHistory.MedicalRecords, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="entity:MedicalRecord">
                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind ConsultationDate, Converter={StaticResource DateConverter}}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind Diagnosis}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>