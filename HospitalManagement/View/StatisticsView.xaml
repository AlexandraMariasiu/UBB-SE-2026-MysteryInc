<?xml version="1.0" encoding="utf-8"?>
<Page  
  x:Class="HospitalManagement.View.Statistics"  
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"  
  xmlns:local="using:HospitalManagement.View"  
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"  
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"  
  xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
  xmlns:helpers="using:HospitalManagement.Utils"
  mc:Ignorable="d"  
    
    >
    <Page.Resources>
        <helpers:StringVisibilityConverter x:Key="StatToVisConverter" />
        <helpers:AxisConverter x:Key="AxisConverter"/>
    </Page.Resources>
    
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" BorderThickness="0,0,1,0" BorderBrush="Gray">
            <ListView ItemsSource="{x:Bind _statisticsViewModel.MenuOptions}"
                      SelectedItem="{x:Bind _statisticsViewModel.SelectedStatistic, Mode=TwoWay}"
                      Padding="10" Margin="0,20,0,0">
                <ListView.Header>
                    <TextBlock Text="Hospital Statistics" FontSize="20" FontWeight="Bold" Margin="10,0,0,20"/>
                </ListView.Header>
            </ListView>
        </Border>

        <Grid Grid.Column="1" Padding="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{x:Bind _statisticsViewModel.SelectedStatistic, Mode=OneWay}" 
                       FontSize="28" FontWeight="SemiLight" Margin="0,0,0,20"/>

            <InfoBar Title="Error" Message="{x:Bind _statisticsViewModel.ErrorMessage, Mode=OneWay}" 
                     IsOpen="{x:Bind _statisticsViewModel.ErrorMessage, Converter={StaticResource StringToBoolConverter}, Mode=OneWay}"
                     Severity="Error" Margin="0,0,0,10"/>

            <Grid Grid.Row="1">
                <lvc:PieChart Series="{x:Bind _statisticsViewModel.CurrentSeries, Mode=OneWay}" 
                              Visibility="{x:Bind _statisticsViewModel.SelectedStatistic, Converter={StaticResource StatToVisConverter}, Mode=OneWay}"/>

                <lvc:CartesianChart Series="{x:Bind _statisticsViewModel.CurrentSeries, Mode=OneWay}" 
                                    XAxes="{x:Bind _statisticsViewModel.XAxes,Converter={StaticResource AxisConverter}, Mode=OneWay}"
                                    Visibility="{x:Bind _statisticsViewModel.SelectedStatistic, Converter={StaticResource StatToVisConverter}, Mode=OneWay}"/>

                <Grid Visibility="{x:Bind _statisticsViewModel.SelectedStatistic, Converter={StaticResource StatToVisConverter}, ConverterParameter='Demographics', Mode=OneWay}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Gender Distribution" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <lvc:PieChart Height="300" Series="{x:Bind _statisticsViewModel.GenderSeries, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Age Groups" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Height="300" Series="{x:Bind _statisticsViewModel.AgeSeries, Mode=OneWay}" XAxes="{x:Bind _statisticsViewModel.AgeXAxes, Converter={StaticResource AxisConverter}, Mode=OneWay}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
