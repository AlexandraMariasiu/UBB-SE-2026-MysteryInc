<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="HospitalManagement.View.DiscountRouletteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="🎡 SPIN FOR A DISCOUNT! 🎡"
    CloseButtonText="Close"
    Background="#1A2A3A">

    <StackPanel Padding="20" Spacing="20" MinWidth="450" MinHeight="550">
        
        <!-- Base Price Display -->
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="Base Price:" FontSize="14" FontWeight="Bold" Foreground="White"/>
            <TextBlock Grid.Row="1" Text="{Binding BasePrice}" FontSize="28" FontWeight="Bold" Foreground="#00FF00"/>
        </Grid>

        <!-- Instructions -->
        <TextBlock Text="Click SPIN to win a random discount!" FontSize="13" Foreground="#FFD700" FontWeight="Bold" TextAlignment="Center"/>

        <!-- Wheel Graphic -->
        <Grid HorizontalAlignment="Center" Width="220" Height="220">
            <Ellipse Width="200" Height="200" Fill="#2A3F54" Stroke="#FFD700" StrokeThickness="2"/>
            <Ellipse Width="130" Height="130" Fill="#1A2A3A" Stroke="#FFD700" StrokeThickness="2"/>
            <Button x:Name="SpinButton"
                    Width="85" Height="85" 
                    CornerRadius="42"
                    Background="#FFD700" 
                    Foreground="Black"
                    Content="SPIN" 
                    FontWeight="Bold" 
                    FontSize="14"
                    Click="SpinButton_Click"
                    IsEnabled="{Binding IsPrimaryButtonEnabled}"/>
        </Grid>

        <!-- Discounts Available -->
        <TextBlock Text="Possible:" FontSize="11" Foreground="Gray" FontWeight="Bold"/>
        <StackPanel Orientation="Horizontal" Spacing="2">
            <Border Background="#FF4444" Padding="6,3" CornerRadius="3"><TextBlock Text="0%" Foreground="White" FontSize="10" FontWeight="Bold"/></Border>
            <Border Background="#FF8844" Padding="6,3" CornerRadius="3"><TextBlock Text="10%" Foreground="White" FontSize="10" FontWeight="Bold"/></Border>
            <Border Background="#FFCC44" Padding="8,3" CornerRadius="3"><TextBlock Text="25%" Foreground="White" FontSize="10" FontWeight="Bold"/></Border>
            <Border Background="#44CC44" Padding="8,3" CornerRadius="3"><TextBlock Text="50%" Foreground="White" FontSize="10" FontWeight="Bold"/></Border>
            <Border Background="#4444FF" Padding="8,3" CornerRadius="3"><TextBlock Text="100%" Foreground="White" FontSize="10" FontWeight="Bold"/></Border>
        </StackPanel>

        <!-- Result Display (starts hidden) -->
        <Border x:Name="ResultBorder" Background="#0D6B3F" Padding="12" CornerRadius="6" Visibility="Collapsed">
            <StackPanel Spacing="6">
                <TextBlock Text="🎉 You Won!" FontSize="14" FontWeight="Bold" Foreground="#00FF00" TextAlignment="Center"/>
                <TextBlock Foreground="Gray" FontSize="11" TextAlignment="Center">Your Discount:</TextBlock>
                <TextBlock Text="{Binding DiscountPercentage}" FontSize="20" FontWeight="Bold" Foreground="#FFD700" TextAlignment="Center"/>
                <TextBlock Foreground="Gray" FontSize="11" TextAlignment="Center">Final Price:</TextBlock>
                <TextBlock Text="{Binding FinalPrice}" FontSize="16" FontWeight="Bold" Foreground="#00FF00" TextAlignment="Center"/>
            </StackPanel>
        </Border>

    </StackPanel>
</ContentDialog>
